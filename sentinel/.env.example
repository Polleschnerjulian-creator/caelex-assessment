# Caelex Sentinel Environment Variables

# Required
SENTINEL_TOKEN=snt_your_token_here
OPERATOR_ID=your-operator-id

# Optional — override config.yaml
CAELEX_API_URL=https://caelex.eu
OPERATOR_NAME=Your Operator Name
MODE=simulator

# Data directory (default: /data in Docker, ./data locally)
SENTINEL_DATA_DIR=./data
