{
  "name": "caelex-assessment",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:deploy": "prisma generate && (prisma db push --skip-generate || echo 'Warning: db push failed, continuing build') && NODE_OPTIONS='--max-old-space-size=7168' next build",
    "db:push:safe": "prisma db push --skip-generate",
    "db:push:force": "prisma db push --skip-generate --accept-data-loss",
    "start": "next start",
    "lint": "next lint",
    "security:audit": "npm audit --audit-level=moderate",
    "security:check": "npm audit",
    "security:outdated": "npm outdated",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:reset": "prisma migrate reset",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:contracts": "vitest run --dir tests/contracts",
    "test:all": "vitest run && playwright test",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit --outputFile=test-results/junit.xml",
    "test:e2e:a11y": "playwright test tests/e2e/accessibility.spec.ts",
    "test:e2e:visual": "playwright test tests/e2e/visual-regression.spec.ts --update-snapshots",
    "test:mutation": "stryker run",
    "lighthouse": "lhci autorun",
    "build:widget": "npx tsx widget.build.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1031.0",
    "@aws-sdk/s3-request-presigner": "^3.1031.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/client": "^7.7.0",
    "@react-email/components": "^1.0.6",
    "@react-email/render": "^2.0.4",
    "@react-pdf/renderer": "^4.5.1",
    "@react-three/drei": "~10.7.7",
    "@react-three/fiber": "~9.6.0",
    "@react-three/postprocessing": "~3.0.4",
    "@sentry/nextjs": "^10.49.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@stripe/stripe-js": "^9.2.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@xyflow/react": "^12.10.1",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "isomorphic-dompurify": "^3.9.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "logsnag": "^1.0.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "^8.0.5",
    "otpauth": "^9.5.0",
    "pdf-lib": "^1.17.1",
    "prisma": "^7.7.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-email": "^6.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.1",
    "resend": "^6.12.0",
    "satellite.js": "^7.0.0",
    "server-only": "^0.0.1",
    "stripe": "^22.0.2",
    "swagger-ui-react": "^5.32.4",
    "three": "^0.184.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@faker-js/faker": "^10.2.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.5.12",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "msw": "^2.12.7",
    "node-mocks-http": "^1.17.2",
    "playwright": "^1.58.1",
    "postcss": "^8.4.33",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
