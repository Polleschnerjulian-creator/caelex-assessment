  actionRequiredCount      Int               @default(0)
  evidencePlaceholderCount Int               @default(0)
  modelUsed                String?
  inputTokens              Int?
  outputTokens             Int?
  generationTimeMs         Int?
  promptVersion            String?
  pdfGenerated             Boolean           @default(false)
  pdfGeneratedAt           DateTime?
  docxGenerated            Boolean           @default(false)
  docxGeneratedAt          DateTime?
  version                  Int               @default(1)
  parentId                 String?
  error                    String?           @db.Text
  reasoningPlanId          String?
  parent                   NCADocument?      @relation("NCADocVersions", fields: [parentId], references: [id])
