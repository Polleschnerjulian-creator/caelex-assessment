// ── NEXUS: Central Asset Registry ──

model Asset {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name        String
  assetType   AssetType
  category    AssetCategory
  description String?       @db.Text
  externalId  String?

  criticality        AssetCriticality       @default(MEDIUM)
  dataClassification DataClassification     @default(INTERNAL)
  operationalStatus  AssetOperationalStatus @default(ACTIVE)

  nis2Relevant       Boolean @default(false)
  euSpaceActRelevant Boolean @default(false)
  nis2Subsector      String?

  location         String?
  jurisdiction     String?
  manufacturer     String?
  commissionedDate DateTime?
  expectedEolDate  DateTime?

  complianceScore Float?
  riskScore       Float?
  lastAssessedAt  DateTime?

  spacecraftId     String?
  spacecraft       Spacecraft?     @relation(fields: [spacecraftId], references: [id])
  operatorEntityId String?
  operatorEntity   OperatorEntity? @relation(fields: [operatorEntityId], references: [id])

  metadata  Json?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?

  requirements     AssetRequirement[]
  dependenciesFrom AssetDependency[]    @relation("NexusDependencySource")
  dependenciesTo   AssetDependency[]    @relation("NexusDependencyTarget")
  suppliers        AssetSupplier[]
  vulnerabilities  AssetVulnerability[]
  personnel        AssetPersonnel[]
  incidentAssets   IncidentAsset[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, assetType])
  @@index([organizationId, criticality])
  @@index([organizationId, complianceScore])
  @@index([spacecraftId])
  @@index([operatorEntityId])
  @@index([organizationId, updatedAt])
  @@index([isDeleted])
}

model AssetRequirement {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  regulationFramework String
  requirementId       String
  requirementLabel    String

  status ComplianceStatus @default(NOT_ASSESSED)

  evidenceId    String?
  evidence      ComplianceEvidence? @relation(fields: [evidenceId], references: [id])
  evidenceFiles String[]

  assessedAt     DateTime?
  assessedBy     String?
  nextReviewDate DateTime?
  notes          String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assetId, regulationFramework, requirementId])
  @@index([assetId])
  @@index([status])
}

model AssetDependency {
  id            String @id @default(cuid())
  sourceAssetId String
  sourceAsset   Asset  @relation("NexusDependencySource", fields: [sourceAssetId], references: [id], onDelete: Cascade)
  targetAssetId String
  targetAsset   Asset  @relation("NexusDependencyTarget", fields: [targetAssetId], references: [id], onDelete: Cascade)

  dependencyType NexusDependencyType
  strength       NexusDependencyStrength @default(HARD)
  description    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Design: One edge per (source, target, type). Strength (HARD/REDUNDANT) is a property of the edge, not a separate edge.
  // SPOF detection checks for HARD edges without a corresponding REDUNDANT alternative path.
  @@unique([sourceAssetId, targetAssetId, dependencyType])
  @@index([sourceAssetId])
  @@index([targetAssetId])
}

model AssetSupplier {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  supplierName String
  supplierType SupplierType
  jurisdiction String?

  riskLevel            AssetCriticality @default(MEDIUM)
  certifications       String[]
  lastAssessed         DateTime?
  contractExpiry       DateTime?
  singlePointOfFailure Boolean          @default(false)
  alternativeAvailable Boolean          @default(false)

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([riskLevel])
}

model AssetVulnerability {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  cveId     String?
  title     String
  severity  AssetCriticality
  cvssScore Float?

  status       VulnerabilityStatus @default(OPEN)
  discoveredAt DateTime            @default(now())
  mitigatedAt  DateTime?
  resolvedAt   DateTime?

  affectedComponent String?
  patchAvailable    Boolean @default(false)
  patchApplied      Boolean @default(false)
  patchVersion      String?
  workaround        String? @db.Text

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([severity])
  @@index([status])
  @@index([discoveredAt])
}

model AssetPersonnel {
  id      String @id @default(cuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  personName       String
  role             PersonnelRole
  accessLevel      PersonnelAccessLevel
  mfaEnabled       Boolean              @default(false)
  lastTraining     DateTime?
  trainingRequired Boolean              @default(true)
  clearanceLevel   String?

  accessGrantedAt DateTime  @default(now())
  accessExpiresAt DateTime?
  isActive        Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assetId])
  @@index([isActive])
}

model ConjunctionEvent {
  id               String            @id @default(cuid())
  organizationId   String
  spacecraftId     String
  noradId          String
  threatNoradId    String
  threatObjectName String?
  threatObjectType String
  conjunctionId    String
  status           ConjunctionStatus @default(NEW)
  riskTier         RiskTier

  peakPc             Float
  peakPcAt           DateTime
  latestPc           Float
  latestMissDistance Float
  tca                DateTime
  relativeSpeed      Float?

  decision          CADecision?
  decisionBy        String?
  decisionAt        DateTime?
  decisionRationale String?     @db.Text

  maneuverPlan       Json?
  maneuverExecutedAt DateTime?
  maneuverVerified   Boolean   @default(false)
  fuelConsumedPct    Float?

  ncaNotified         Boolean   @default(false)
  ncaNotifiedAt       DateTime?
  reportGenerated     Boolean   @default(false)
  verityAttestationId String?

  closedAt     DateTime?
  closedReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  cdmRecords    CDMRecord[]
  escalationLog CAEscalationLog[]

  @@unique([organizationId, conjunctionId])
  @@index([organizationId, status])
  @@index([spacecraftId, status])
  @@index([noradId, tca])
  @@index([riskTier, status])
  @@index([tca])
}

model CDMRecord {
  id                   String   @id @default(cuid())
  conjunctionEventId   String
  cdmId                String   @unique
  creationDate         DateTime
  tca                  DateTime
  missDistance         Float
  relativeSpeed        Float?
  collisionProbability Float
  probabilityMethod    String?

  sat1StateVector  Json?
  sat1Covariance   Json?
  sat2StateVector  Json?
  sat2Covariance   Json?
  sat2Maneuverable String?

  rawCdm    Json
  riskTier  RiskTier
  createdAt DateTime @default(now())

  source String @default("space_track")

  conjunctionEvent ConjunctionEvent @relation(fields: [conjunctionEventId], references: [id], onDelete: Cascade)

  @@index([conjunctionEventId, creationDate])
}

model CAEscalationLog {
  id                 String            @id @default(cuid())
  conjunctionEventId String
  previousTier       RiskTier
  newTier            RiskTier
  previousStatus     ConjunctionStatus
  newStatus          ConjunctionStatus
  triggeredBy        String
  details            String?
  createdAt          DateTime          @default(now())

  conjunctionEvent ConjunctionEvent @relation(fields: [conjunctionEventId], references: [id], onDelete: Cascade)

  @@index([conjunctionEventId, createdAt])
}

model CAConfig {
  id             String @id @default(cuid())
  organizationId String @unique

  emergencyPcThreshold Float @default(0.001)
  highPcThreshold      Float @default(0.0001)
  elevatedPcThreshold  Float @default(0.00001)
  monitorPcThreshold   Float @default(0.0000001)

  notifyOnTier      RiskTier @default(HIGH)
  emergencyEmailAll Boolean  @default(true)

  autoCloseAfterTcaHours Int @default(24)

  ncaAutoNotify   Boolean @default(false)
  ncaJurisdiction String?

  defaultAssigneeId String?

  leolabsEnabled Boolean @default(false)
  leolabsApiKey  String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

// ============================================
// HUB: PROJECT MANAGEMENT
// ============================================

enum HubProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum HubMemberRole {
  ADMIN
  MEMBER
  VIEWER
}

enum HubTaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum HubTaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model HubProject {
  id             String           @id @default(cuid())
  organizationId String
  name           String
  description    String?
  status         HubProjectStatus @default(ACTIVE)
  color          String?
  ownerId        String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User               @relation("HubProjectOwner", fields: [ownerId], references: [id])
  members      HubProjectMember[]
  tasks        HubTask[]
  labels       HubLabel[]
  timeEntries  HubTimeEntry[]

  @@index([organizationId, status])
  @@index([ownerId])
}

model HubProjectMember {
  id        String        @id @default(cuid())
  projectId String
  userId    String
  role      HubMemberRole @default(MEMBER)
  joinedAt  DateTime      @default(now())

  project HubProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User       @relation("HubProjectMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model HubTask {
  id          String          @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      HubTaskStatus   @default(TODO)
  priority    HubTaskPriority @default(MEDIUM)
  assigneeId  String?
  creatorId   String?
  dueDate     DateTime?
  position    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  project     HubProject       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?            @relation("HubTaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator     User?            @relation("HubTaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  comments    HubTaskComment[]
  taskLabels  HubTaskLabel[]
  timeEntries HubTimeEntry[]

  @@index([projectId, status])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([projectId, position])
}

model HubTaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   HubTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User?   @relation("HubTaskComments", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([authorId])
}

model HubLabel {
  id        String   @id @default(cuid())
  projectId String
  name      String
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project HubProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   HubTaskLabel[]

  @@unique([projectId, name])
}

model HubTaskLabel {
  taskId  String
  labelId String

  task  HubTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label HubLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

model HubTimeEntry {
  id          String   @id @default(cuid())
  projectId   String
  taskId      String?
  userId      String
  date        DateTime @db.Date
  hours       Float
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project HubProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    HubTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)
  user    User       @relation("HubTimeEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@index([projectId, date])
  @@index([taskId])
}

model HubCalendarEvent {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  description    String?
  date           DateTime @db.Date
  startTime      String? // HH:mm format, null = all-day
  endTime        String? // HH:mm format
  color          String   @default("#3B82F6")
  creatorId      String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator      User         @relation("HubCalendarEvents", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([organizationId, date])
  @@index([creatorId])
}

// ============================================
// HAZARD REPORT (CNES/FSOA Template Nr. 20)
// ============================================

enum HazardType {
  COLLISION
  REENTRY
  EXPLOSION
  CONTROL_LOSS
  TOXICITY
  DEBRIS_GENERATION
  CYBER
}

enum HazardSeverity {
  CATASTROPHIC // score: 4
  CRITICAL // score: 3
  MARGINAL // score: 2
  NEGLIGIBLE // score: 1
}

enum HazardMitigationStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum AcceptanceStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MitigationType {
  TECHNICAL
  OPERATIONAL
  PROCEDURAL
}

enum SourceModule {
  SHIELD
  DEBRIS
  INCIDENTS
  EPHEMERIS
  MANUAL
}

enum TargetNCA {
  CNES
  RDI
  MINISTRY_LU
  BELSPO
}

model HazardEntry {
  id             String             @id @default(cuid())
  organizationId String
  spacecraftId   String
  hazardId       String // e.g. "G01", "G02"
  hazardType     HazardType
  sourceModule   SourceModule
  sourceRecordId String? // FK to source record in Shield/Debris/etc.
  title          String
  description    String             @db.Text
  severity       HazardSeverity
  likelihood     Int // 1-5
  riskIndex      Int // severity_score × likelihood, computed
  mitigations    HazardMitigation[]

  mitigationStatus HazardMitigationStatus @default(OPEN)
  residualRisk     String?                @db.Text
  regulatoryRefs   String[] // e.g. ["FSOA Art. 34", "ECSS-Q-ST-40-02C Task 4"]

  acceptanceStatus    AcceptanceStatus @default(PENDING)
  acceptedBy          String?
  acceptedAt          DateTime?
  verityAttestationId String?

  // Predictive Hazard Intelligence
  isPredicted         Boolean   @default(false)
  predictedBreachDate DateTime? // When the threshold will be exceeded
  forecastConfidence  String? // HIGH, MEDIUM, LOW
  forecastSourceDate  DateTime? // When the forecast was calculated

  // FMECA operator input (Chapter 4.4)
  fmecaNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  spacecraft     Spacecraft            @relation(fields: [spacecraftId], references: [id], onDelete: Cascade)
  reportVersions HazardReportVersion[] @relation("HazardReportHazards")

  @@unique([spacecraftId, hazardId])
  @@index([organizationId])
  @@index([spacecraftId, hazardType])
  @@index([spacecraftId, acceptanceStatus])
  @@index([mitigationStatus])
  @@index([isPredicted])
}

model HazardMitigation {
  id            String         @id @default(cuid())
  hazardEntryId String
  type          MitigationType
  description   String         @db.Text
  implementedAt DateTime?
  verifiedBy    String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  hazardEntry HazardEntry @relation(fields: [hazardEntryId], references: [id], onDelete: Cascade)

  @@index([hazardEntryId])
}

model HazardReportVersion {
  id             String    @id @default(cuid())
  organizationId String
  spacecraftId   String
  version        Int // Auto-incremented per spacecraft
  targetNCA      TargetNCA
  language       String    @default("en")
  milestone      String? // SRR, PDR, CDR, FRR, etc.

  // PDF storage
  fileHash    String // SHA-256 of the PDF buffer
  fileSize    Int
  storagePath String? // R2/S3 path if stored remotely
  pdfData     Bytes? // Inline storage for small reports

  // Verity report-level attestation
  verityAttestationId String?
  reportSignature     String? // Hex signature of the report hash

  // Snapshot of hazard IDs at generation time
  hazardSnapshotIds String[]

  // Metadata
  generatedBy String
  generatedAt DateTime @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  hazards      HazardEntry[] @relation("HazardReportHazards")

  @@unique([spacecraftId, version])
  @@index([organizationId])
  @@index([spacecraftId])
}

// ─── Regulatory Ontology ─────────────────────────────────────────────────────

model OntologyNode {
  id         String    @id @default(cuid())
  type       String
  code       String    @unique
  label      String
  properties Json
  validFrom  DateTime  @default(now())
  validUntil DateTime?
  confidence Float     @default(1.0)
  sourceFile String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  outEdges OntologyEdge[] @relation("FromNode")
  inEdges  OntologyEdge[] @relation("ToNode")

  @@index([type])
  @@index([type, code])
  @@index([validFrom, validUntil])
}

model OntologyEdge {
  id         String    @id @default(cuid())
  type       String
  fromNodeId String
  toNodeId   String
  properties Json?
  weight     Float     @default(1.0)
  validFrom  DateTime  @default(now())
  validUntil DateTime?

  fromNode OntologyNode @relation("FromNode", fields: [fromNodeId], references: [id], onDelete: Cascade)
  toNode   OntologyNode @relation("ToNode", fields: [toNodeId], references: [id], onDelete: Cascade)

  @@unique([fromNodeId, toNodeId, type])
  @@index([fromNodeId])
  @@index([toNodeId])
  @@index([type])
  @@index([fromNodeId, type])
  @@index([toNodeId, type])
}

model OntologyVersion {
  id          String   @id @default(cuid())
  version     String
  description String
  nodeCount   Int
  edgeCount   Int
  seededFrom  String
  seededAt    DateTime @default(now())

  @@index([version])
}

// ─── ATLAS Source Monitoring ────────────────────────────────────────

model AtlasSourceCheck {
  id             String           @id @default(cuid())
  sourceId       String // Legal source ID (e.g., "DE-SATDSIG-2007")
  jurisdiction   String // Country code (e.g., "DE")
  sourceUrl      String // URL that was checked
  contentHash    String? // SHA-256 hash of fetched content
  previousHash   String? // Previous hash for comparison
  /// Latest fetched body, truncated to ~200 KB. Retained so that when the
  /// next fetch differs we can diff current-vs-previous for the Claude
  /// summary without re-fetching the original URL again.
  currentContent String? // @db.Text
  status         AtlasCheckStatus @default(PENDING)
  httpStatus     Int? // HTTP status code from fetch
  errorMessage   String? // Error details if fetch failed
  lastChecked    DateTime         @default(now())
  lastChanged    DateTime? // When the content hash last changed
  reviewedAt     DateTime? // When an admin reviewed the change
  reviewedBy     String? // Admin user ID who reviewed
  reviewNote     String? // Admin notes on the change
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([sourceId])
  @@index([status])
  @@index([jurisdiction])
  @@index([lastChecked])
  @@index([lastChanged])
}

enum AtlasCheckStatus {
  PENDING // Not yet checked
  UNCHANGED // Content hash matches
  CHANGED // Content hash differs — needs review
  ERROR // Fetch failed
  REVIEWED // Admin reviewed the change
  DISMISSED // Admin dismissed (false positive)
}

/// H-I2 — deduplication table for stripe webhook events. stripe
/// sends each event at-least-once; we persist the event id after
/// processing so replays become idempotent no-ops.
model ProcessedStripeEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  eventType     String
  processedAt   DateTime @default(now())

  @@index([processedAt])
}

/// M20 — append-only history of content changes detected by the cron.
/// Each time AtlasSourceCheck.previousHash != contentHash, the cron
/// writes a new row here. Lets us answer "what changed on date X and
/// at what revision?" without the previousHash overwrite destroying
/// prior versions.
model AtlasSourceCheckHistory {
  id           String   @id @default(cuid())
  sourceId     String // Legal-source id this history belongs to
  jurisdiction String
  contentHash  String // New hash at detection time
  previousHash String? // Prior hash if present
  httpStatus   Int?
  detectedAt   DateTime @default(now())

  /// Text snapshot at the NEW hash (truncated ~200 KB). Retained so that
  /// the admin-review and public-history redline viewers can render the
  /// before/after diff without re-fetching the source URL — important
  /// when the URL has since been amended again or gone 404.
  newContent     String?
  /// Text snapshot at the PREVIOUS hash. Paired with newContent so each
  /// history row is self-contained for diffing. null on the first-ever
  /// detection for that sourceId (no prior state existed).
  previousContent String?

  /// Claude-generated 1-2 sentence summary of what changed. Written
  /// asynchronously after the check; null until the summariser runs.
  /// "COSMETIC_ONLY" signals no substantive legal change.
  diffSummaryAi   String?
  /// Optional structured tags like ["article-added", "date-change"].
  diffKeyChanges  Json?
  /// Review state for this specific amendment candidate.
  reviewStatus    AtlasAmendmentReviewStatus @default(PENDING)
  reviewedAt      DateTime?
  reviewedBy      String?
  reviewNote      String?
  /// Flag set by the reviewer when an amendment has been written back
  /// into the static LegalSource.amendments[] array (via PR/data-file
  /// edit). Lets the admin queue mark entries as 'already integrated'.
  integratedAt    DateTime?

  @@index([sourceId, detectedAt])
  @@index([jurisdiction, detectedAt])
  @@index([reviewStatus, detectedAt])
}

enum AtlasAmendmentReviewStatus {
  PENDING // Awaiting admin review
  APPROVED // Admin confirmed a real amendment
  REJECTED // Admin dismissed as noise/false positive
}

/// Phase-2 auto-update — discovered source candidates from public RSS /
/// Atom / SPARQL feeds (UNOOSA, Gesetze-im-Internet, BGBl, EUR-Lex ...)
/// that aren't yet indexed in ALL_SOURCES. Admin reviews each, either
/// adds it to the static data files (APPROVED → manual PR), or dismisses
/// it as out-of-scope (REJECTED). dedupKey prevents the same entry from
/// being queued twice across runs.
model AtlasPendingSourceCandidate {
  id             String                             @id @default(cuid())
  /// ISO code or "INT" / "EU" when supranational.
  jurisdiction   String
  /// Which feed this came from — "UNOOSA", "GESETZE_IM_INTERNET", "EUR_LEX", etc.
  feedSource     String
  title          String
  url            String
  description    String?
  publishedAt    DateTime?
  /// Keywords that matched the space-law filter.
  matchKeywords  Json?
  detectedAt     DateTime                           @default(now())
  reviewStatus   AtlasAmendmentReviewStatus         @default(PENDING)
  reviewedAt     DateTime?
  reviewedBy     String?
  reviewNote     String?
  /// Unique dedupe key — feed identifier ∶∶ normalized URL. Stops the
  /// same entry from re-inserting on every poll.
  dedupKey       String                             @unique

  @@index([reviewStatus, detectedAt])
  @@index([jurisdiction, detectedAt])
  @@index([feedSource, detectedAt])
}

// ─── ATLAS Bookmarks (per-user) ────────────────────────────────────

/// Per-user saved items across Atlas (legal sources, country profiles,
/// authorities). Anonymous users fall back to localStorage client-side;
/// on login, the client migrates local bookmarks into this table.
model AtlasBookmark {
  id        String            @id @default(cuid())
  userId    String
  itemId    String // e.g. "EU-NIS2", "DE", "INT-UNOOSA"
  itemType  AtlasBookmarkType
  title     String
  subtitle  String?
  href      String
  note      String? // optional free-form annotation
  createdAt DateTime          @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, createdAt])
}

enum AtlasBookmarkType {
  source
  jurisdiction
  authority
}

// ─── ATLAS Curated Updates (admin → users) ─────────────────────────

model AtlasUpdate {
  id           String              @id @default(cuid())
  title        String // Short headline: "Germany: NIS2 Implementation Act in force"
  description  String // 1-3 sentence detail
  jurisdiction String? // Country code if relevant (e.g., "DE")
  sourceId     String? // Related legal source ID if relevant
  category     AtlasUpdateCategory @default(AMENDMENT)
  publishedAt  DateTime            @default(now())
  createdBy    String // Admin user ID
  isPublished  Boolean             @default(true)

  @@index([publishedAt])
  @@index([jurisdiction])
  @@index([isPublished])
  /// M21: composite index for the typical "latest 20 published updates"
  /// query — avoids two separate index scans.
  @@index([isPublished, publishedAt])
}

enum AtlasUpdateCategory {
  NEW_LAW // New legislation enacted
  AMENDMENT // Existing law amended
  RATIFICATION // Treaty ratified/acceded
  DRAFT // Draft legislation published
  INSTITUTIONAL // Agency created/renamed/restructured
  NIS2 // NIS2 transposition update
  EU_SPACE_ACT // EU Space Act progress
  DATA_UPDATE // ATLAS database updated
}

// ============================================
// ATLAS: ANNOTATIONS
// ============================================

model AtlasAnnotation {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  sourceId       String
  text           String   @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // C-3 fix: organizationId MUST be part of the unique key. Without
  // it, a user who belongs to two orgs (e.g. outside counsel) would
  // collide on (userId, sourceId) and silently overwrite the
  // annotation from the other org. See docs/security/atlas-audit-2026-04-22.md.
  @@unique([userId, organizationId, sourceId])
  @@index([userId])
  @@index([organizationId])
  @@index([sourceId])
}

// ============================================
// ATLAS: ALERTS (SUBSCRIPTIONS + NOTIFICATIONS)
// ============================================
//
// Two-model design:
//
// AtlasAlertSubscription — "this user wants to be notified about
//   changes to this target." Target is either a specific source
//   (targetType=SOURCE, targetId = AtlasSourceCheck.sourceId) or
//   an entire jurisdiction (targetType=JURISDICTION, targetId = ISO
//   country code / "EU" / "INT"). User-scoped, unique per target
//   so toggle is idempotent.
//
// AtlasNotification — a concrete notification the user sees in
//   /atlas/alerts. Created by the dispatch helper (src/lib/atlas/
//   notify.ts) whenever an admin approves an AtlasSourceCheck
//   amendment or publishes an AtlasUpdate. Fan-out at dispatch
//   time keeps the subscription list on the critical path small
//   (nothing to join at read time).
//
// Data retention: notifications are soft-ephemeral — after ~90
// days they can be hard-deleted by a retention cron. For now no
// cleanup exists; adding one is a follow-up.

enum AtlasAlertTargetType {
  SOURCE
  JURISDICTION
}

model AtlasAlertSubscription {
  id             String               @id @default(cuid())
  userId         String
  organizationId String
  targetType     AtlasAlertTargetType
  targetId       String // sourceId for SOURCE, ISO code for JURISDICTION
  createdAt      DateTime             @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // One subscription per (user, target) — toggle is idempotent.
  @@unique([userId, targetType, targetId])
  // Fan-out index: when an amendment fires for a given source /
  // jurisdiction, the dispatch helper queries on (targetType, targetId)
  // to enumerate subscribers.
  @@index([targetType, targetId])
  @@index([userId])
  @@index([organizationId])
}

enum AtlasNotificationKind {
  // An admin approved an AtlasSourceCheck amendment — the source's
  // content has materially changed and subscribers to that source
  // (and to its jurisdiction) get notified.
  SOURCE_AMENDED

  // An admin published an AtlasUpdate scoped to a jurisdiction —
  // subscribers to that jurisdiction get notified.
  JURISDICTION_UPDATE

  // An admin published a general AtlasUpdate that's broadcast to
  // every member of every org. No subscription required.
  ADMIN_BROADCAST
}

model AtlasNotification {
  id             String                @id @default(cuid())
  userId         String
  organizationId String
  kind           AtlasNotificationKind
  title          String // Short headline shown in the list
  summary        String                @db.Text // 1-3 sentence body
  // Origin of the notification — lets the UI deep-link back to
  // either a source detail page (sources/[id]) or a jurisdiction
  // page (jurisdictions/[code]). Kept as strings (not relations)
  // because sources live in a static data file, not the DB.
  targetType     String
  targetId       String
  sourceId       String? // optional: specific source that triggered

  readAt    DateTime? // null = unread
  createdAt DateTime  @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, readAt]) // "unread count" + "unread list" queries
  @@index([userId, createdAt]) // "latest N for this user"
  @@index([createdAt]) // retention-cleanup cron
}

// ============================================
// PASSWORD RESET (C-4)
// ============================================
//
// Self-service password reset flow. The raw token is generated with
// crypto.randomBytes(32).toString("hex") (256-bit CSPRNG), emailed to
// the user via the /atlas-reset-password link, and NEVER stored in
// the DB — we store only its SHA-256 hash so a DB leak can't be used
// to hijack in-flight resets.
//
// Tokens are single-use (markedUsedAt on consume), expire after 60
// minutes, and any outstanding token for the same user is invalidated
// when a new one is issued. The forgot-password endpoint always
// returns 200 regardless of whether a user exists (anti-enumeration).

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // SHA-256 hex of the raw token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// LEGAL NETWORK — PHASE 1 (Identity & Linking)
// ============================================
//
// Bilateral trust-bridge between Atlas (law firm organisations) and
// Caelex (operator organisations). A LegalMatter is the long-lived
// record of a firm↔client relationship; invitations are ephemeral
// tokens that expire after 72h; every access gets a hash-chained
// audit log entry.
//
// See docs/superpowers/specs/2026-04-23-legal-network-phase-1-design.md
// for the full design rationale.

enum OrganizationType {
  OPERATOR // default — uses Caelex for compliance
  LAW_FIRM // uses Atlas to represent operator clients
  BOTH // rare; e.g. firm with in-house satellite subsidiary
}

enum MatterStatus {
  PENDING_INVITE // token sent, no acceptance yet
  PENDING_CONSENT // token accepted with amendment; awaiting counter-signature
  ACTIVE
  SUSPENDED // operator paused; can be resumed
  CLOSED // normal termination
  REVOKED // forced termination (trust breach)
}

enum NetworkSide {
  ATLAS
  CAELEX
}

enum LegalMatterAction {
  READ_ASSESSMENT
  READ_AUTHORIZATION
  READ_DOCUMENT
  READ_TIMELINE
  READ_INCIDENT
  EXPORT_DOCUMENT
  SUMMARY_GENERATED
  MEMO_DRAFTED
  MATTER_REVOKED // lifecycle event logged as an access entry for chain continuity
  MATTER_SUSPENDED
  MATTER_RESUMED
  SCOPE_AMENDED
}

/// Long-lived record of a law-firm ↔ operator matter.
model LegalMatter {
  id String @id @default(cuid())

  // Identities — both sides of the relationship
  lawFirmOrgId String
  clientOrgId  String

  // Human labels
  name        String
  reference   String? // firm's internal matter number (e.g. "BHO-2026-112")
  description String?

  // Scope — array of ScopeItem, validated by the application layer.
  // Kept as Json rather than a sub-model because Phase 2 may add
  // free-form fields per category (e.g. per-jurisdiction filter).
  scope Json

  // Lifecycle
  status           MatterStatus
  invitedBy        String // userId of the initiator
  invitedFrom      NetworkSide
  invitedAt        DateTime    @default(now())
  acceptedAt       DateTime?
  acceptedBy       String? // userId of the counter-signer
  revokedAt        DateTime?
  revokedBy        String?
  revocationReason String?

  // Effective window — both set at ACTIVE transition (nullable while
  // in PENDING_*). Default duration 12 months from acceptedAt.
  effectiveFrom  DateTime?
  effectiveUntil DateTime?

  // Mutual consent proof — SHA-256 of the canonical handshake bundle.
  // Recomputed from stored fields at verification time; any drift
  // fails the integrity check.
  handshakeHash String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lawFirmOrg Organization @relation("LegalMatterFirm", fields: [lawFirmOrgId], references: [id], onDelete: Cascade)
  clientOrg  Organization @relation("LegalMatterClient", fields: [clientOrgId], references: [id], onDelete: Cascade)

  accessLogs  LegalMatterAccessLog[]
  invitations LegalMatterInvitation[]

  // Phase 2 workspace data
  tasks         MatterTask[]
  notes         MatterNote[]
  conversations MatterConversation[]
  artifacts     MatterArtifact[]

  @@unique([lawFirmOrgId, clientOrgId, reference])
  @@index([clientOrgId, status])
  @@index([lawFirmOrgId, status])
  @@index([effectiveUntil])
}

/// Ephemeral invitation. Lives only until `consumedAt` is stamped or
/// `expiresAt` passes. After consumption the matter transitions out
/// of PENDING_INVITE.
model LegalMatterInvitation {
  id                     String    @id @default(cuid())
  matterId               String
  tokenHash              String    @unique // SHA-256 of the one-time token
  expiresAt              DateTime // 72h from creation
  consumedAt             DateTime?
  proposedScope          Json
  proposedDurationMonths Int?

  // Amendment tracking: when the recipient narrows the scope at accept
  // time, a second invitation is generated with the amended scope for
  // the original inviter to counter-sign. This field links that chain.
  amendmentOf String? // previous invitationId if this is a counter-proposal

  createdAt DateTime @default(now())

  matter LegalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId])
  @@index([expiresAt])
}

// ─── Phase 2 — Matter Workspace ─────────────────────────────────
//
// The firm-side working surface of a LegalMatter. Tasks and notes
// live inside a matter and are visible only to members of the firm
// organisation (the operator can VIEW them via matter-inspection,
// but not by default — that's a Phase 2+ RBAC decision). No Caelex-
// pull yet; firm-owned data only.

enum MatterTaskStatus {
  OPEN
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum MatterTaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

/// A single actionable item attached to a matter. Typical examples:
/// "Prepare memo on FR licensing timeline", "Submit ITU coordination
/// filing by 2026-06-14", "Review draft response from BNetzA".
model MatterTask {
  id       String @id @default(cuid())
  matterId String

  title       String
  description String?
  dueDate     DateTime?
  status      MatterTaskStatus   @default(OPEN)
  priority    MatterTaskPriority @default(NORMAL)

  // Author + current assignee (both firm-side users). Nullable
  // assignee because tasks may be unassigned until a partner picks
  // them up.
  createdBy  String
  assignedTo String?

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matter LegalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId, status])
  @@index([matterId, dueDate])
}

enum MatterChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum ArtifactKind {
  // Structured tool outputs — rendered by dedicated card types
  COMPLIANCE_OVERVIEW // from load_compliance_overview
  CITATIONS // from search_legal_sources
  MEMO // from draft_memo_to_note
  // Fallback: plain assistant text that didn't come from a tool
  TEXT
  // Future: COMPARISON, CHECKLIST, TIMELINE, CHART
}

/// A "card" on the matter pinboard. Created when Claude calls a tool
/// (or replies in free-form text); represents a concrete work-product
/// the lawyer can reference, pin, or delete.
///
/// payload is kind-specific JSON validated on the client by the
/// matching ArtifactCard variant. Storing as Json keeps the schema
/// stable while kinds evolve.
model MatterArtifact {
  id             String  @id @default(cuid())
  matterId       String
  conversationId String? // null for manually-created cards

  kind    ArtifactKind
  title   String
  payload Json

  // Layout hints
  widthHint String  @default("medium") // "small" | "medium" | "large"
  position  Int     @default(0) // masonry-order, lower = earlier
  pinned    Boolean @default(false)

  createdBy String // userId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matter LegalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId, position])
  @@index([matterId, pinned, createdAt])
}

/// A conversation thread scoped to a LegalMatter. The thread persists
/// across sessions so lawyers can return to ongoing strategy chats.
/// Each matter may have many conversations (split by topic).
model MatterConversation {
  id       String @id @default(cuid())
  matterId String

  title         String // auto-generated from first user message, user-editable
  createdBy     String
  lastMessageAt DateTime @default(now())

  // Running counters so the workspace list can show "23 Msgs · 4.2k tokens"
  // without a N+1 aggregation.
  messageCount Int @default(0)
  totalTokens  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matter   LegalMatter                 @relation(fields: [matterId], references: [id], onDelete: Cascade)
  messages MatterConversationMessage[]

  @@index([matterId, lastMessageAt])
}

model MatterConversationMessage {
  id             String @id @default(cuid())
  conversationId String

  role    MatterChatRole
  content String         @db.Text

  // Usage telemetry — populated on assistant messages from Claude's
  // response. Zero for user messages.
  tokensInput  Int @default(0)
  tokensOutput Int @default(0)

  createdAt DateTime @default(now())

  conversation MatterConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

/// Free-form notes / memo drafts attached to a matter. Rich-text
/// content stored as serialised JSON string (TipTap/ProseMirror-
/// compatible) so we can upgrade the editor without schema changes.
/// Phase 2 ships with plain-text content; richer later.
model MatterNote {
  id       String @id @default(cuid())
  matterId String

  title   String
  content String @db.Text // can be large — memo drafts

  // Version tracking via a parent-child chain: each edit creates a
  // new row with `parentNoteId` pointing back. Enables diff views
  // later without overwriting history.
  parentNoteId String?
  isLatest     Boolean @default(true)

  createdBy  String
  lastEditBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matter LegalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId, isLatest, updatedAt])
  @@index([parentNoteId])
}

/// Append-only audit trail of every cross-organisation data access
/// OR matter-lifecycle event. Entries are hash-chained for tamper
/// evidence; the daily audit-chain-anchor cron signs chain heads
/// into the Verity attestation service.
model LegalMatterAccessLog {
  id       String @id @default(cuid())
  matterId String

  // Who
  actorUserId String?
  actorOrgId  String
  actorSide   NetworkSide

  // What
  action       LegalMatterAction
  resourceType String // Prisma model name, e.g. "CybersecurityAssessment"
  resourceId   String?

  // Authorisation trace
  matterScope String // which scope category authorised this access
  context     Json? // arbitrary metadata

  // Request fingerprint
  ipAddress String?
  userAgent String?

  // Tamper-evident hash chain. `previousHash` of the first entry is
  // the matter's `handshakeHash`. `entryHash` = SHA-256(previousHash
  // || canonicalJSON(thisEntryWithoutHashes)).
  previousHash String?
  entryHash    String

  createdAt DateTime @default(now())

  matter LegalMatter @relation(fields: [matterId], references: [id], onDelete: Cascade)

  @@index([matterId, createdAt])
}
