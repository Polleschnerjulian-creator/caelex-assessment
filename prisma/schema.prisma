  vatNumber      String?
  billingAddress Json?

  // Status
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members                OrganizationMember[]
  invitations            OrganizationInvitation[]
  spacecraft             Spacecraft[]
  registrations          SpaceObjectRegistration[]
  ssoConnection          SSOConnection?
  apiKeys                ApiKey[]
  webhooks               Webhook[]
  subscription           Subscription?
  comments               Comment[] // Collaboration: organization's comments
  activities             Activity[] // Collaboration: organization's activities
  complianceEvidence     ComplianceEvidence[] // Audit Center: org-scoped compliance evidence
  regulatoryRequirements RegulatoryRequirement[] // ACE: org-scoped regulatory requirements
  astraConversations     AstraConversation[] // ASTRA AI conversations
  generatedDocuments     GeneratedDocument[] // AI-generated compliance documents
  healthScore            CustomerHealthScore? // CEO Analytics: customer health
  submissionPackages     SubmissionPackage[] // NCA Portal: document packages
  breachReports          BreachReport[] // GDPR Art. 33/34 breach reports
  widgetConfigs          WidgetConfig[] // Embeddable widget configurations
  churnInterventions     ChurnIntervention[] // Churn intervention tracking
  regulatoryUpdateReads  RegulatoryUpdateRead[] // Regulatory feed read tracking
  ncaDocuments           NCADocument[] // Generate 2.0: NCA documents
  ncaDocPackages         NCADocPackage[] // Generate 2.0: NCA submission packages
  stakeholderEngagements StakeholderEngagement[] // Network: stakeholder engagements
  dataRooms              DataRoom[] // Network: secure data rooms
  attestations           ComplianceAttestation[] // Network: compliance attestations
  operatorProfile        OperatorProfile? // Unified operator profile

  // Legal Network Phase 1 — trust bridge between Atlas (law firms)
  // and Caelex (operators). An Organization may be an operator, a
  // law firm, or both. See 2026-04-23-legal-network-phase-1-design.md.
  orgType                OrganizationType   @default(OPERATOR)
  legalMattersAsFirm     LegalMatter[]      @relation("LegalMatterFirm")
  legalMattersAsClient   LegalMatter[]      @relation("LegalMatterClient")

  // Context Omnipresence: provenance & signed snapshots
  derivationTraces DerivationTrace[] // Per-field provenance chain (append-only)
  profileSnapshots ProfileSnapshot[] // Frozen + signed operator-profile snapshots

  // Assure: Regulatory Readiness Intelligence
