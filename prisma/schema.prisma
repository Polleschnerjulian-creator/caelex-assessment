// ─── GDPR Breach Notification (Art. 33/34) ───

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BreachStatus {
  DETECTED
  INVESTIGATING
  CONTAINED
  RESOLVED
  CLOSED
}

model BreachReport {
  id             String        @id @default(cuid())
  reportedById   String
  reportedBy     User          @relation(fields: [reportedById], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  // Classification
  severity BreachSeverity @default(MEDIUM)
  status   BreachStatus   @default(DETECTED)

  // Description
  title                String
  description          String @db.Text
  affectedDataTypes    String // e.g. "personal data, email addresses"
  affectedDataSubjects Int    @default(0) // estimated number of affected individuals

  // Timeline
  discoveredAt DateTime
  reportedAt   DateTime  @default(now())
  containedAt  DateTime?
  resolvedAt   DateTime?

  // Notifications (GDPR Art. 33: authority within 72h, Art. 34: subjects without undue delay)
  authorityNotifiedAt DateTime?
  subjectsNotifiedAt  DateTime?

  // Action log
  notes Json? // Timeline of actions taken: [{ timestamp, action, by }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([severity])
  @@index([organizationId])
  @@index([reportedById])
  @@index([discoveredAt])
}

// ============================================
// CUSTOMER RETENTION & ACQUISITION
// ============================================

// ─── Churn Intervention ───

enum InterventionStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CHURNED
}

model ChurnIntervention {
  id             String             @id @default(cuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  triggerReason  String
  healthScore    Int
  previousScore  Int?
  status         InterventionStatus @default(PENDING)
  actionTaken    String?            @db.Text
  resolvedAt     DateTime?
