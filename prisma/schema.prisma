// ═══════════════════════════════════════════════════════════════════════════════
// ACE — Autonomous Compliance Evidence Engine
// ═══════════════════════════════════════════════════════════════════════════════

// Regulation-agnostic requirement registry. Stores requirements from ALL
// regulations (NIS2, EU Space Act, UK Space Act, COPUOS, etc.) in a single
// table. Each requirement knows what evidence it demands, how to auto-assess
// compliance, and which operator types it applies to.
model RegulatoryRequirement {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Regulation identification
  regulationType RegulationType // NIS2, EU_SPACE_ACT, UK_SPACE_ACT, etc.
  requirementId  String // Unique within regulationType: "nis2-001", "uksa-lic-3"

  // Content
  title        String
  description  String  @db.Text
  category     String // "cybersecurity", "debris_mitigation", "authorization"
  subcategory  String? // More specific grouping
  jurisdiction String? // "EU", "UK", "US", "AU", "global"

  // Evidence specification — what ACE hunts for
  evidenceRequired Json // string[] of required evidence descriptions
  assessmentFields Json? // AssessmentField[] definitions for structured assessment
  complianceRule   Json? // ComplianceRule definition for auto-assessment

  // Applicability
  mandatory    Boolean @default(true)
  applicableTo Json? // { operatorTypes?, sectors?, organizationSizes? }
  severity     String? // "critical", "major", "moderate", "minor"

  // Guidance
  implementationGuide     String? @db.Text
  implementationTimeWeeks Int?

  // Regulatory source
  sourceArticle  String? // "Art. 21(2)(a)", "Section 3(1)", "§4 LuftVG"
  sourceDocument String? // "Regulation (EU) 2022/2555", "Space Industry Act 2018"

  // Cross-references to other frameworks
  crossReferences Json? // { euSpaceActRef?, iso27001Ref?, enisaControlIds?, etc. }

  // Validity
  validFrom  DateTime?
  validUntil DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  evidenceMappings EvidenceRequirementMapping[]

  @@unique([organizationId, regulationType, requirementId])
  @@index([organizationId, regulationType])
  @@index([regulationType, category])
  @@index([jurisdiction])
  @@index([mandatory])
}

// Maps evidence records to regulatory requirements with coverage tracking.
// A single piece of evidence can satisfy multiple requirements (DIRECT, PARTIAL,
// SUPPORTING), and a single requirement can be covered by multiple pieces of evidence.
model EvidenceRequirementMapping {
  id             String @id @default(cuid())
  organizationId String

  // Evidence → Requirement link
  evidenceId    String
  evidence      ComplianceEvidence    @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  requirementId String
  requirement   RegulatoryRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  // Coverage details
  mappingType     EvidenceMappingType @default(DIRECT)
  coveragePercent Float               @default(100) // 0-100, how much of the requirement this covers
  autoMapped      Boolean             @default(false) // Was this mapping created by ACE or manually?
  notes           String?             @db.Text

  // Validity (evidence may only satisfy a requirement for a specific period)
  validFrom  DateTime  @default(now())
  validUntil DateTime?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([evidenceId, requirementId])
  @@index([requirementId, organizationId])
  @@index([evidenceId])
  @@index([organizationId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// SENTINEL — Autonomous Compliance Evidence Collection
// ═══════════════════════════════════════════════════════════════════════════════

model SentinelAgent {
  id                String       @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name              String
  sentinelId        String       @unique
  publicKey         String       @db.Text
  token             String       @unique // Hashed bearer token for auth
  status            String       @default("PENDING") // PENDING, ACTIVE, REVOKED
  lastSeen          DateTime?
  lastPacketAt      DateTime?
  chainPosition     Int          @default(0)
  lastChainHash     String?
  version           String?
  configHash        String?
  enabledCollectors String[] // ["orbit_debris", "cybersecurity", ...]

  // Chain verification checkpoint (for incremental verification)
  lastVerifiedPosition Int?
  lastVerifiedHash     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packets     SentinelPacket[]
  crossChecks CrossVerification[]

  @@index([organizationId])
  @@index([sentinelId])
  @@index([status])
}

model SentinelPacket {
  id             String        @id @default(cuid())
  packetId       String        @unique
  agentId        String
  agent          SentinelAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  satelliteNorad String?

  // Data
  dataPoint        String
  values           Json
  sourceSystem     String
  collectionMethod String
  collectedAt      DateTime
  complianceNotes  String[]

  // Regulation mapping
  regulationMapping Json

  // Integrity
  contentHash    String
  previousHash   String
  chainPosition  Int
  signature      String  @db.Text
  signatureValid Boolean @default(false)
  chainValid     Boolean @default(false)

  // Trust
  crossVerified Boolean @default(false)
  trustScore    Float?

  // Processing
  processedAt DateTime @default(now())

  crossChecks CrossVerification[]

  @@index([agentId])
  @@index([satelliteNorad])
  @@index([dataPoint])
  @@index([collectedAt])
  @@index([chainPosition])
  // Composite indexes for common query patterns (SVA assessment)
  @@index([agentId, satelliteNorad, dataPoint, collectedAt])
  @@index([agentId, dataPoint, crossVerified])
  @@index([agentId, chainPosition])
  @@index([processedAt])
}

model CrossVerification {
  id       String         @id @default(cuid())
  packetId String
  packet   SentinelPacket @relation(fields: [packetId], references: [id], onDelete: Cascade)
  agentId  String
  agent    SentinelAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)

  dataPoint    String
  agentValue   Float
  publicValue  Float
  publicSource String // "celestrak", "space_track", "esa_discos"
  delta        Float

  result     String // "VERIFIED", "PLAUSIBLE", "ANOMALY"
  confidence Float

  verifiedAt      DateTime  @default(now())
  publicDataEpoch DateTime?

  @@index([packetId])
  @@index([agentId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// VERITY — Privacy-Preserving Cryptographic Attestation System
// ═══════════════════════════════════════════════════════════════════════════════

model VerityAttestation {
  id             String        @id @default(cuid())
  attestationId  String        @unique
  operatorId     String
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  satelliteNorad String?

  regulationRef  String
  dataPoint      String
  thresholdType  String
  thresholdValue Float
  result         Boolean
  claimStatement String

  // Evidence
  valueCommitment String
  evidenceSource  String
  trustScore      Float
  trustLevel      String
  collectedAt     DateTime

  // Sentinel
  sentinelAnchor    Json?
  crossVerification Json?

  // Issuer Key
  issuerKeyId     String
  issuerPublicKey String
  signature       String

  // Full signed attestation JSON (for embedding in Certificates)
  fullAttestation Json

  // Commitment Secret (encrypted, optional)
  encryptedSecret String?

  // Manual attestation fields
  description String?
  entityId    String?

  // Revocation
  revokedAt     DateTime?
  revokedReason String?

  issuedAt  DateTime @default(now())
  expiresAt DateTime

  certificateLinks VerityCertificateClaim[]

  @@index([operatorId])
  @@index([organizationId])
  @@index([regulationRef])
  @@index([issuerKeyId])
  @@index([collectedAt])
  @@index([revokedAt])
  @@index([entityId])
}

model VerityCertificate {
  id             String  @id @default(cuid())
  certificateId  String  @unique
  operatorId     String
  satelliteNorad String?

  // Full signed certificate JSON (incl. embedded attestations)
  certificate Json

  // Metadata
  version        String   @default("1.0")
  claimsCount    Int
  regulationRefs String[]
  minTrustLevel  String
  sentinelBacked Int
  crossVerified  Int

  // Issuer
  issuerKeyId String

  isPublic Boolean @default(false)

  issuedAt  DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  verificationCount Int       @default(0)
  lastVerifiedAt    DateTime?

  claims VerityCertificateClaim[]

  @@index([operatorId])
  @@index([certificateId])
  @@index([isPublic])
  @@index([issuerKeyId])
}

model VerityCertificateClaim {
  certificateId String
  attestationId String

  certificate VerityCertificate @relation(fields: [certificateId], references: [id])
  attestation VerityAttestation @relation(fields: [attestationId], references: [id])

  @@id([certificateId, attestationId])
}

model VerityPassport {
  id             String       @id @default(cuid())
  passportId     String       @unique @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  operatorId     String

  satelliteNorad String?
  satelliteName  String?
  label          String

  attestationCount   Int
  certificateCount   Int
  complianceScore    Int
  scoreBreakdown     Json
  attestationSummary Json
  jurisdictions      String[]

  isPublic     Boolean   @default(true)
  accessToken  String?   @unique
  viewCount    Int       @default(0)
  lastViewedAt DateTime?

  generatedAt DateTime  @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?

  @@index([organizationId])
  @@index([operatorId])
  @@index([passportId])
  @@index([isPublic, revokedAt])
}

model VerityP2PRequest {
  id        String @id @default(cuid())
  requestId String @unique @default(cuid())

  requesterOrgId String
  requesterName  String
  requesterEmail String?

  targetOrgId   String
  targetNoradId String?

  regulationRefs String[]
  purpose        String
  message        String?

  status          String    @default("PENDING")
  responseAt      DateTime?
  responseMessage String?
  attestationIds  String[]
  certificateId   String?

  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([requesterOrgId])
  @@index([targetOrgId, status])
  @@index([requestId])
}

model VerityAuditChainEntry {
  id             String @id @default(cuid())
  organizationId String
  sequenceNumber Int

  eventType  String
  entityId   String
  entityType String
  eventData  Json

  entryHash    String
  previousHash String

  createdAt DateTime @default(now())

  @@unique([organizationId, sequenceNumber])
  @@index([organizationId, createdAt])
  @@index([entityId])
  @@index([entryHash])
}

model VerityIssuerKey {
  id               String    @id @default(cuid())
  keyId            String    @unique
  publicKeyHex     String    @unique
  encryptedPrivKey String
  algorithm        String    @default("Ed25519")
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now())
  rotatedAt        DateTime?

  @@index([active])
  @@index([keyId])
}

// ─── Verity Merkle Transparency Log (Phase 2 — pillar 4.5) ────────────────
//
// Append-only log of every VerityAttestation, surfaced to third parties via
// signed tree heads (STHs) so retroactive deletion is detectable without
// trusting Caelex. See src/lib/verity/transparency/log-store.ts for writers
// and src/app/api/v1/verity/transparency/* for the public read surface.

model VerityLogLeaf {
  id            String   @id @default(cuid())
  leafIndex     Int      @unique // 0-based position in the append-only log
  attestationId String   @unique // FK-by-value to VerityAttestation.attestationId
  leafHash      String // hex SHA-256 per RFC 6962 hashLeaf(serialized attestation)
  appendedAt    DateTime @default(now())

  @@index([attestationId])
  @@index([appendedAt])
}

model VerityLogSTH {
  id          String   @id @default(cuid())
  treeSize    Int      @unique // number of leaves covered
  rootHash    String // hex SHA-256 root
  issuerKeyId String // Verity Ed25519 key that signed this STH
  signature   String // hex Ed25519 signature over canonical STH signing bytes
  timestamp   DateTime @default(now())
  version     String   @default("v1")

  @@index([treeSize])
  @@index([timestamp])
}

// ═══════════════════════════════════════════════════════════════════════════════
// EPHEMERIS — Predictive Compliance Intelligence
// ═══════════════════════════════════════════════════════════════════════════════

model SatelliteComplianceState {
  id           String       @id @default(cuid())
  noradId      String
  operatorId   String
  organization Organization @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  overallScore Int // 0-100
  moduleScores Json // { orbital: {...}, fuel: {...}, ... }
  dataSources  Json // { sentinel: {...}, verity: {...}, ... }

  // Compliance Horizon
  horizonDays       Int? // Days until first breach (null = no breach predictable)
  horizonRegulation String? // Which regulation breaches first
  horizonConfidence String // HIGH / MEDIUM / LOW

  dataFreshness String // LIVE / RECENT / STALE / NO_DATA

  stateJson     Json? // Full public state snapshot
  satelliteName String?

  calculatedAt DateTime @default(now())

  @@unique([noradId, operatorId])
  @@index([operatorId])
  @@index([horizonDays])
}

model SatelliteComplianceStateHistory {
  id           String       @id @default(cuid())
  noradId      String
  operatorId   String
  organization Organization @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  overallScore      Int
  moduleScores      Json // Snapshot of module scores for this day
  horizonDays       Int?
  horizonRegulation String?
  dataFreshness     String

  stateJson Json? // Full public state snapshot
  alerts    Json? // Serialized activeAlerts array

  // Forecast percentiles (derived from compliance horizon confidence)
  forecastP10 Float?
  forecastP50 Float?
  forecastP90 Float?

  // Inputs hash for reproducibility
  // SHA-256 over: Sentinel time series hashes + TLE age + F10.7 + constants version
  inputsHash String?

  calculatedAt DateTime @default(now())

  @@index([noradId, calculatedAt])
  @@index([operatorId, calculatedAt])
}

model EphemerisForecast {
  id           String       @id @default(cuid())
  noradId      String
  operatorId   String
  organization Organization @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  // Forecast data
  forecastCurves   Json // Array<ForecastCurve>
  complianceEvents Json // Array<ComplianceEvent>
  horizonDays      Int?

  // Model inputs (for reproducibility)
  f107Used     Float
  modelVersion String @default("1.0")

  calculatedAt DateTime @default(now())
  expiresAt    DateTime // Forecasts expire after 24h

  @@index([noradId])
  @@index([calculatedAt])
}

model SatelliteAlert {
  id           String       @id @default(cuid())
  noradId      String
  operatorId   String
  organization Organization @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  type          String // FUEL_LOW, THRUSTER_DEGRADED, etc.
  severity      String // CRITICAL, HIGH, MEDIUM, LOW
  title         String
  description   String  @db.Text
  regulationRef String?

  // Hysteresis: dedupe-key = noradId + type + regulationRef
  dedupeKey String

  triggeredAt    DateTime  @default(now())
  resolvedAt     DateTime?
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?

  @@index([noradId])
  @@index([operatorId, severity])
  @@index([resolvedAt])
  @@index([dedupeKey])
}

model OrbitalData {
  id           String     @id @default(cuid())
  spacecraftId String
  noradId      String
  altitude     Float
  inclination  Float
  eccentricity Float
  period       Float
  epoch        DateTime
  rawGp        Json? // CelesTrak GP/JSON record
  createdAt    DateTime   @default(now())
  spacecraft   Spacecraft @relation(fields: [spacecraftId], references: [id], onDelete: Cascade)

  @@index([spacecraftId, createdAt])
  @@index([noradId, epoch])
}

model SolarFluxRecord {
  id          String   @id @default(cuid())
  f107        Float
  kpIndex     Float?
  isPredicted Boolean  @default(false)
  observedAt  DateTime
  source      String   @default("NOAA_SWPC")
  createdAt   DateTime @default(now())

  @@unique([observedAt, source])
  @@index([observedAt])
  @@index([isPredicted, observedAt])
}

model SpaceWeatherEvent {
  id          String    @id @default(cuid())
  eventType   String // GEOMAGNETIC_STORM, SOLAR_RADIATION, RADIO_BLACKOUT
  severity    String // G1-G5, S1-S5, R1-R5
  kpIndex     Float?
  startedAt   DateTime
  endedAt     DateTime?
  description String?
  source      String    @default("NOAA_SWPC")
  createdAt   DateTime  @default(now())

  @@index([eventType, startedAt])
  @@index([severity])
}

model OptimizationResult {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Input Snapshot
  inputJson     Json
  weightProfile String // "startup" | "enterprise" | "government" | "balanced" | "custom"

  // Re-Flagging Context
  spacecraftId        String?
  spacecraft          Spacecraft? @relation(fields: [spacecraftId], references: [id])
  currentJurisdiction String?

  // Results
  resultJson      Json
  topJurisdiction String
  topScore        Float

  createdAt DateTime @default(now())

  @@index([organizationId, createdAt])
}

