  rrsSnapshots     RRSSnapshot[] // Historical RRS snapshots
  assureShareLinks AssureShareLink[] // Permissioned share links
  assureDDPackages AssureDDPackage[] // Due diligence packages
  rcrRatings       RegulatoryCreditRating[] // RCR rating history
  rcrAppeals       RCRAppeal[] // Rating appeals

  // Assure Platform: Investment Readiness
  assureCompanyProfile      AssureCompanyProfile?
  assureRisks               AssureRisk[]
  assureMaterials           AssureMaterial[]
  assureDataRooms           AssureDataRoom[]
  investmentReadinessScores InvestmentReadinessScore[]
  assureMilestones          AssureMilestone[]

  // Multi-tenancy: org-scoped models
  auditLogs                AuditLog[]
  documents                Document[]
  debrisAssessments        DebrisAssessment[]
  cybersecurityAssessments CybersecurityAssessment[]
  insuranceAssessments     InsuranceAssessment[]
  environmentalAssessments EnvironmentalAssessment[]
  nis2Assessments          NIS2Assessment[]
  craAssessments           CRAAssessment[]

  // Sentinel: autonomous compliance evidence agents
  sentinelAgents SentinelAgent[]

  // CRM: linked company record (when this organization becomes a paying customer)
  crmCompany CrmCompany?

  // Verity: compliance attestations (multi-tenant FK)
  verityAttestations VerityAttestation[]
  verityPassports    VerityPassport[]

  // Ephemeris: predictive compliance intelligence
  satelliteComplianceStates  SatelliteComplianceState[]
  satelliteComplianceHistory SatelliteComplianceStateHistory[]
  ephemerisForecasts         EphemerisForecast[]
  satelliteAlerts            SatelliteAlert[]

  // Optimizer: regulatory arbitrage optimization results
  optimizationResults OptimizationResult[]

  // Ephemeris Universal: generic operator entities
  operatorEntities   OperatorEntity[]
  entityDependencies EntityDependency[]

  // Shield: Conjunction Assessment & Collision Avoidance
  conjunctionEvents ConjunctionEvent[]
  caConfig          CAConfig?

  // NEXUS: Space Asset Register
  assets Asset[]

  // HUB: Project Management
  hubProjects       HubProject[]
  hubCalendarEvents HubCalendarEvent[]

  // Hazard Report (CNES/FSOA Template Nr. 20)
  hazardEntries        HazardEntry[]
  hazardReportVersions HazardReportVersion[]

  // Legal Portal
  legalEngagements LegalEngagement[]

  // ATLAS: per-user annotations on legal sources (org-scoped for team queries)
  atlasAnnotations AtlasAnnotation[]

