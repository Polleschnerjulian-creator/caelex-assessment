enum RegulationType {
  EU_SPACE_ACT
  NIS2
  CYBERSECURITY
  DEBRIS
  ENVIRONMENTAL
  INSURANCE
  AUTHORIZATION
  REGISTRATION
  SUPERVISION
  NATIONAL_SPACE_LAW
  UK_SPACE_ACT
  US_REGULATORY
  COPUOS_IADC
  ITU_SPECTRUM
  EXPORT_CONTROL
}

enum EvidenceSourceType {
  MANUAL
  DOCUMENT_UPLOAD
  API_IMPORT
  AUTOMATED
  EXTERNAL
}

enum EvidenceMappingType {
  DIRECT
  PARTIAL
  SUPPORTING
}

enum EvidenceStatus {
  DRAFT
  SUBMITTED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum EvidenceType {
  DOCUMENT
  SCREENSHOT
  ATTESTATION
  CERTIFICATE
  LOG_EXTRACT
  POLICY
  PROCEDURE
  TEST_RESULT
  EXTERNAL_REPORT
  OTHER
}

model ComplianceEvidence {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy      String // userId of the creator (audit trail)

  // What this evidence proves compliance for
  regulationType RegulationType
  requirementId  String // e.g., "art-74", "nis2-req-1", "debris-req-5"

  // Evidence details
  title        String
  description  String?        @db.Text
  evidenceType EvidenceType
  status       EvidenceStatus @default(DRAFT)

  // Validity period
  validFrom  DateTime?
  validUntil DateTime?

  // Review
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?   @db.Text

  // ACE: Hash-chain integrity (mirrors AuditLog pattern)
  entryHash    String? // SHA-256 hash of this evidence record
  previousHash String? // Hash of the previous evidence record (chain link)

  // ACE: Source and confidence tracking
  sourceType EvidenceSourceType @default(MANUAL)
  confidence Float? // 0.0-1.0, how reliable is this evidence
  metadata   Json? // Additional structured metadata (scan job ID, source URL, etc.)

  // Linked documents (from existing Document vault)
  documents ComplianceEvidenceDocument[]

  // ACE: Requirement mappings (coverage tracking)
  requirementMappings EvidenceRequirementMapping[]
  assetRequirements   AssetRequirement[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId, regulationType, requirementId])
  @@index([organizationId])
  @@index([organizationId, regulationType])
  @@index([regulationType, requirementId])
  @@index([status])
  @@index([sourceType])
  @@index([entryHash])
}

model ComplianceEvidenceDocument {
  id         String             @id @default(cuid())
  evidenceId String
  evidence   ComplianceEvidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  documentId String
  document   Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@unique([evidenceId, documentId])
  @@index([evidenceId])
  @@index([documentId])
}

