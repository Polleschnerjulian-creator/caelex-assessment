model NCADocument {
  id                       String            @id @default(cuid())
  userId                   String
  organizationId           String
  packageId                String?
  documentType             NCADocumentType
  title                    String
  language                 String            @default("en")
  status                   NCADocumentStatus @default(DRAFT)
  content                  Json? // ReportSection[]
  rawContent               String?           @db.Text
  editedContent            Json?
