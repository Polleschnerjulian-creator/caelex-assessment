{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Atlas",
  "version": "0.1.0",
  "identifier": "com.caelex.atlas",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://atlas.caelex.com"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Atlas",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "focus": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Caelex Atlas — legal-research client for space-law counsel",
    "longDescription": "Atlas is the desktop client for the Caelex legal-research platform. Drafting studio, jurisdiction comparator, mandate management, and AI-assisted compliance work — all in a native window.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": null,
      "exceptionDomain": ""
    }
  }
}
