# ═══════════════════════════════════════════════════════════════════════════════
# Caelex Environment Variables
# Copy this file to .env.local and fill in the values
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core ───
NODE_ENV=development
# Public app URL (used for CSRF origin validation, SSO callbacks, emails)
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ─── Database (Optional for assessment-only mode) ───
# PostgreSQL connection string (Neon, Supabase, or other provider)
# If not set, the app runs in assessment-only mode (no dashboard, no auth)
# Append &connection_limit=5 for Neon serverless (auto-added if missing)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# ─── Authentication (Optional for assessment-only mode) ───
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here-at-least-32-characters"
# Production URL (required in production)
AUTH_URL="https://your-domain.com"
# Set to "true" to enable SessionProvider on the client (requires AUTH_SECRET)
NEXT_PUBLIC_AUTH_ENABLED="true"

# ─── OAuth Providers (Optional) ───
# Google OAuth - get from console.cloud.google.com
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── Encryption (Required in Production) ───
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=""
# Generate with: openssl rand -hex 16
ENCRYPTION_SALT=""

# ─── Rate Limiting (Recommended) ───
# Upstash Redis - get from console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Monitoring (Recommended in Production) ───
# Sentry - get from sentry.io
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# ─── Email (Required for Notifications) ───
# SMTP settings for password reset and notifications
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@caelex.io"
SMTP_FROM_NAME="Caelex Compliance"

# ─── Cron Jobs (Required for Production) ───
# Secret for Vercel Cron job authentication
# Generate with: openssl rand -base64 32
CRON_SECRET=""

# ─── Verity (Required for Attestation Signing) ───
# 32-byte hex key for AES-256-GCM encryption of Ed25519 private keys
# Generate with: openssl rand -hex 32
VERITY_MASTER_KEY=""

# Admin seed script: comma-separated list of emails to grant admin role
# Used by: npx tsx prisma/seed-admin.ts
ADMIN_EMAILS="admin@example.com"

# ─── Payments (Optional) ───
# Stripe - get from dashboard.stripe.com
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── ASTRA AI Assistant (Optional) ───
# Anthropic API key for ASTRA compliance assistant
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=""
